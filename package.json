{
  "name": "wordmark",
  "version": "3.6.1",
  "description": "Client-side, backend-free AI assistant platform for OpenAI and xAI Grok (Responses API) plus local LM Studio/Ollama servers, with tool calling, MCP servers, web/X search, image generation, TTS, and fully local storage.",
  "main": "index.html",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:https": "vite --host",
    "build": "vite build",
    "preview": "vite preview --port 8080",
    "start": "vite preview --port 8080",
    "test": "node --experimental-test-module-mocks --import ./tests/helpers/registerLoaders.mjs --test \"tests/**/*.spec.ts\"",
    "test:watch": "node --experimental-test-module-mocks --import ./tests/helpers/registerLoaders.mjs --test --watch \"tests/**/*.spec.ts\"",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc --noEmit -p tsconfig.tests.json",
    "lint": "npx eslint \"src/ts/**/*.ts\"",
    "lint:fix": "npx eslint \"src/ts/**/*.ts\" --fix",
    "validate": "npx html-validate index.html src/html/*.html",
    "serve": "npm run start",
    "cert:generate": "openssl req -x509 -newkey rsa:4096 -keyout key.pem -out cert.pem -days 365 -nodes -subj '/C=US/ST=Local/L=Local/O=Wordmark/CN=localhost'",
    "deps:check": "npx npm-check-updates",
    "deps:update": "npx npm-check-updates -u && npm install",
    "docker:build": "docker build -t wordmark .",
    "docker:run": "docker run --rm -p 8080:80 wordmark:latest"
  },
  "keywords": [
    "ai",
    "assistant",
    "chatbot",
    "openai",
    "xai",
    "grok",
    "responses-api",
    "lmstudio",
    "ollama",
    "local-ai",
    "llm",
    "generative-ai",
    "conversational-ai",
    "tool-calling",
    "mcp",
    "tts",
    "web-app",
    "typescript",
    "privacy",
    "client-side",
    "open-source"
  ],
  "author": {
    "name": "Dustin Whyte",
    "url": "https://github.com/h1ddenpr0cess20"
  },
  "license": "MIT",
  "homepage": "https://wordmark-chatbot.vercel.app/",
  "repository": {
    "type": "git",
    "url": "https://github.com/h1ddenpr0cess20/Wordmark.git"
  },
  "bugs": {
    "url": "https://github.com/h1ddenpr0cess20/Wordmark/issues"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions",
    "not dead",
    "not ie 11"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "html-validate": "^11.4.0",
    "jsdom": "^29.1.1",
    "npm-check-updates": "^22.2.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  },
  "files": [
    "index.html",
    "src/",
    "public/",
    "README.md",
    "LICENSE"
  ],
  "directories": {
    "doc": "."
  },
  "config": {
    "port": 8080,
    "https_port": 8443
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5"
  }
}
